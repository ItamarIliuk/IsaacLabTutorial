{
  "name": "Workshop Quadrúpede - Isaac Sim Completo (Local)",
  "image": "nvcr.io/nvidia/isaac-sim:5.1.0",

  "runArgs": [
    "--gpus", "all",
    "--network", "host",
    "--ipc", "host",
    "--ulimit", "memlock=-1",
    "--ulimit", "stack=67108864"
  ],

  "containerEnv": {
    "ACCEPT_EULA": "Y",
    "PRIVACY_CONSENT": "Y",
    "ISAAC_PATH": "/isaac-sim",
    "ISAACSIM_PATH": "/isaac-sim"
  },

  "forwardPorts": [8888, 6006, 49100, 47995, 47996, 47997, 48011, 48012],
  "portsAttributes": {
    "8888":  { "label": "JupyterLab",              "onAutoForward": "openBrowser" },
    "6006":  { "label": "TensorBoard",              "onAutoForward": "notify" },
    "49100": { "label": "Isaac Sim WebSocket" },
    "47995": { "label": "Omniverse WebRTC Streaming" }
  },

  "postCreateCommand": "bash ${containerWorkspaceFolder}/workshop/setup/setup_devcontainer.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.debugpy",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/isaac-sim/kit/python/bin/python3",
        "python.terminal.activateEnvironment": false,
        "python.analysis.extraPaths": [
          "/isaac-sim/exts/omni.isaac.lab/source",
          "/isaac-sim/kit/python/lib/python3.10/site-packages"
        ],
        "jupyter.jupyterServerType": "local",
        "jupyter.notebookFileRoot": "${workspaceFolder}/workshop/notebooks",
        "terminal.integrated.env.linux": {
          "ISAAC_PATH": "/isaac-sim",
          "ISAACSIM_PATH": "/isaac-sim"
        }
      }
    }
  }
}
